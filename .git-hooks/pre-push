#!/usr/bin/env bash
# Runs `make quality` before every push so CI failures (fmt drift, lint
# violations, undocumented env vars) surface locally first. Fast — usually
# under a couple seconds since it doesn't invoke docker.
#
# Bypass: git push --no-verify

set -e

if ! command -v make >/dev/null 2>&1; then
  echo "pre-push: 'make' not found in PATH; skipping quality gate" >&2
  exit 0
fi

echo "→ pre-push: running make quality (bypass with: git push --no-verify)"
make quality

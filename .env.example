# =============================================================================
# Open Brain — local Docker Compose configuration
# =============================================================================
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# `make env` will bootstrap this file for you and generate MCP_ACCESS_KEY.
#
# Quickstart:
#   cp .env.example .env
#   make env       # generate MCP_ACCESS_KEY if blank
#   # set DB_PASSWORD and your LLM credentials below, then:
#   make setup     # boots the whole stack and verifies it
# =============================================================================


# -----------------------------------------------------------------------------
# Postgres (local container — no cloud provider involved)
# -----------------------------------------------------------------------------
DB_NAME=openbrain
DB_USER=openbrain

# REQUIRED. Generate with: openssl rand -hex 24
DB_PASSWORD=

# Host port to publish Postgres on. Default 55432 to avoid clashing with a
# host Postgres on 5432. Pick a different port per profile if you run
# multiple stacks side-by-side (e.g. work=65433, personal=65434).
DB_PORT=55432

# DB_HOST is set automatically by docker-compose to "db" (the compose service
# name). Override only if you run the server outside the compose stack and
# need to point it at a different Postgres host.
DB_HOST=


# -----------------------------------------------------------------------------
# MCP server
# -----------------------------------------------------------------------------
# The shared secret your AI clients will send as `?key=<value>` or in the
# `x-brain-key` header. `make env` generates this for you if blank.
# REQUIRED. 32-byte hex (openssl rand -hex 32).
MCP_ACCESS_KEY=

# Host port to publish the MCP server on. Pick a different port per profile.
MCP_PORT=8000

# Smoke-test / offline-dev mode. When true, the server returns deterministic
# stub embeddings and metadata without calling any LLM provider. Boot the
# stack and run `make smoke` without any LLM credentials to verify the
# plumbing. Set to false (or unset) for real use.
LLM_MOCK=false


# -----------------------------------------------------------------------------
# GitHub webhook ingestion (optional)
# -----------------------------------------------------------------------------
# Capture merged PRs and published releases from GitHub repos as thoughts.
# Leave empty to disable the /webhook/github endpoint (returns 404).
#
# Setup:
#   1. Generate a secret:        openssl rand -hex 32
#   2. Set GITHUB_WEBHOOK_SECRET below
#   3. `make restart` to pick up the new value
#   4. Expose your server publicly (cloudflared, ngrok) since GitHub needs to reach it
#   5. In GitHub repo settings → Webhooks → Add webhook:
#        Payload URL:  https://<your-public-url>/webhook/github
#        Content type: application/json
#        Secret:       <the value you set below>
#        Events:       Pull requests, Releases (start there)
GITHUB_WEBHOOK_SECRET=

# Linear webhook (optional). Set the same value here and in Linear's webhook
# settings. Captures Issue events with action=update where state.type=completed.
LINEAR_WEBHOOK_SECRET=

# Sentry webhook (optional). Set in Sentry's Internal Integration → Webhooks.
# Captures issue.resolved events. Sentry's signing header is sentry-hook-signature.
SENTRY_WEBHOOK_SECRET=

# Generic webhook (optional). Caller passes the secret as `Authorization: Bearer <secret>`.
# Body: either {"content": "thought text", "metadata": {...}} (top-level shape),
# or any shape paired with GENERIC_WEBHOOK_CONTENT_PATH for dot-path extraction.
GENERIC_WEBHOOK_SECRET=

# Optional dot-paths into the body for non-OB1-shaped payloads. Leave both
# empty if your callers send {"content": "..."} directly.
#   Example for a Slack event: GENERIC_WEBHOOK_CONTENT_PATH=event.text
#   Example for a Stripe event: GENERIC_WEBHOOK_CONTENT_PATH=data.object.description
GENERIC_WEBHOOK_CONTENT_PATH=
GENERIC_WEBHOOK_METADATA_PATH=


# -----------------------------------------------------------------------------
# /metrics (Prometheus exposition)
# -----------------------------------------------------------------------------
# /metrics is always served. Leave METRICS_TOKEN empty for public access (the
# typical pattern when the server is on a private network). Set it to require
# `Authorization: Bearer <token>` from your scraper if the server is exposed
# publicly via a tunnel.
METRICS_TOKEN=

# /healthz reports `degraded` when the most recent embedding API success is
# older than this many seconds. 0 (default) disables the staleness check —
# useful for LLM_MOCK and idle dev environments. Set to e.g. 600 in prod to
# alert when your provider goes dark.
EMBEDDING_STALE_SECONDS=0


# =============================================================================
# LLM backend
# =============================================================================
# Pick ONE of the four blocks below by uncommenting it. Comment out the others.
# Embeddings always use an OpenAI-compatible endpoint. Chat / metadata
# extraction can use OpenAI-compatible OR Anthropic (set CHAT_PROVIDER).
# =============================================================================


# -----------------------------------------------------------------------------
# Block A — GitHub Models (recommended; covered by your Copilot subscription)
# -----------------------------------------------------------------------------
# Auth: a GitHub Personal Access Token (classic or fine-grained, models:read).
# Embeddings: text-embedding-3-small (1536-dim — matches the schema).
EMBEDDING_API_BASE=https://models.github.ai/inference
# REQUIRED for real (non-mock) captures. Your GitHub PAT with models:read.
EMBEDDING_API_KEY=
EMBEDDING_MODEL=openai/text-embedding-3-small

CHAT_PROVIDER=openai
# Empty CHAT_API_BASE / CHAT_API_KEY = inherit from EMBEDDING_API_BASE / KEY.
CHAT_API_BASE=
CHAT_API_KEY=
CHAT_MODEL=openai/gpt-4o-mini


# -----------------------------------------------------------------------------
# Block B — Anthropic Claude for metadata, GitHub Models for embeddings
# -----------------------------------------------------------------------------
# Claude does not provide an embedding model, so embeddings still go through
# an OpenAI-compatible endpoint (GitHub Models, OpenRouter, OpenAI direct).
# To use Claude: set CHAT_PROVIDER=anthropic above, then fill ANTHROPIC_API_KEY.
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_VERSION=2023-06-01


# -----------------------------------------------------------------------------
# Block C — OpenRouter (legacy upstream OB1 default)
# -----------------------------------------------------------------------------
# EMBEDDING_API_BASE=https://openrouter.ai/api/v1
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=openai/text-embedding-3-small
# CHAT_PROVIDER=openai
# CHAT_API_BASE=https://openrouter.ai/api/v1
# CHAT_API_KEY=
# CHAT_MODEL=openai/gpt-4o-mini


# -----------------------------------------------------------------------------
# Block D — Ollama (full air-gap, no outbound calls)
# -----------------------------------------------------------------------------
# Requires a separate Ollama container or local install with both an embedding
# model and a chat model pulled. NOTE: nomic-embed-text is 768-dim, not 1536 —
# you must edit db/migrations/001_init.sql and 002_search_function.sql to use
# vector(768) before the first `make up`. After thoughts exist you cannot
# change dimensions without re-embedding everything.
#
# EMBEDDING_API_BASE=http://host.docker.internal:11434/v1
# EMBEDDING_API_KEY=ollama
# EMBEDDING_MODEL=nomic-embed-text
# CHAT_PROVIDER=openai
# CHAT_API_BASE=http://host.docker.internal:11434/v1
# CHAT_API_KEY=ollama
# CHAT_MODEL=llama3.1:8b


# -----------------------------------------------------------------------------
# Block E — AWS Bedrock via LiteLLM gateway
# -----------------------------------------------------------------------------
# Bedrock isn't OpenAI-compatible (SigV4 signing, per-model request shapes),
# so this fork ships a LiteLLM container under the `bedrock` compose profile
# that translates OpenAI-format requests to Bedrock.
#
# To enable:
#   1. Set AWS_* below
#   2. Set CHAT_API_BASE / EMBEDDING_API_BASE to http://litellm:4000
#   3. Set CHAT_MODEL / EMBEDDING_MODEL to a name from ci/litellm-config.yaml
#   4. Bring the stack up with: BACKEND=bedrock make up
#      (or: docker compose --profile bedrock up -d)
#
# CAVEAT: Bedrock embedding models produce 1024-dim (Cohere) or 512/1024
# (Titan), NOT 1536. If you route embeddings through Bedrock, edit
# db/migrations/001_init.sql + 002_search_function.sql to use vector(1024)
# AND wipe the db volume before first boot. Recommended hybrid: keep
# embeddings on GitHub Models (no schema change) and route only chat
# through Bedrock.

LITELLM_PORT=4000
AWS_REGION=us-east-1
LITELLM_LOG=INFO

# Two ways to source Bedrock credentials:
#
# 1. AWS_PROFILE — named profile from ~/.aws/credentials. Used by
#    `make verify-bedrock` to export-credentials into the LiteLLM container.
#    Works with static keys, SSO, or assume-role profiles.
#
# 2. Direct keys (below). Use this if you don't have ~/.aws/credentials,
#    or if you're running in CI/headless contexts.
#
# `make verify-bedrock` prefers AWS_PROFILE if both are set.
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Example values to switch chat to Bedrock once litellm is up. Uncomment
# AND comment out the chat lines in your chosen Block A/B above.
#
# CHAT_PROVIDER=openai
# CHAT_API_BASE=http://litellm:4000
# CHAT_API_KEY=anything-litellm-doesnt-check
# CHAT_MODEL=bedrock/claude-haiku
